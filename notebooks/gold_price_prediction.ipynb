# CELL 1: Install Libraries
!pip install yfinance pandas numpy matplotlib seaborn scikit-learn tensorflow --quiet

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from datetime import datetime
import warnings
warnings.filterwarnings('ignore')

import yfinance as yf
from sklearn.preprocessing import MinMaxScaler
import tensorflow as tf
from tensorflow.keras.models import Sequential, Model
from tensorflow.keras.layers import (Dense, LSTM, Conv1D, Dropout, Input, 
                                      Concatenate, Multiply, Lambda)
from tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau
from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score

print(f"TensorFlow: {tf.__version__}")
print("Libraries loaded!")

# CELL 2: Download Data
ticker = "GC=F"
gold_data = yf.download(ticker, start="2010-01-01", end=datetime.now().strftime("%Y-%m-%d"), progress=False)
print(f"Downloaded {len(gold_data)} rows")

# CELL 3: FEATURE ENGINEERING (CRITICAL!)
df = gold_data.copy()
df = df.fillna(method='ffill').fillna(method='bfill')
close = df['Close'].values

def create_features(data):
    df_feat = pd.DataFrame()
    df_feat['close'] = data
    
    # Technical indicators
    df_feat['returns'] = df_feat['close'].pct_change()
    df_feat['log_returns'] = np.log(df_feat['close'] / df_feat['close'].shift(1))
    df_feat['ma5_ratio'] = df_feat['close'] / df_feat['close'].rolling(5).mean()
    df_feat['ma10_ratio'] = df_feat['close'] / df_feat['close'].rolling(10).mean()
    df_feat['ma20_ratio'] = df_feat['close'] / df_feat['close'].rolling(20).mean()
    df_feat['volatility'] = df_feat['close'].rolling(10).std() / df_feat['close'].rolling(10).mean()
    df_feat['momentum_5'] = df_feat['close'] / df_feat['close'].shift(5) - 1
    df_feat['momentum_10'] = df_feat['close'] / df_feat['close'].shift(10) - 1
    df_feat['roc'] = (df_feat['close'] - df_feat['close'].shift(5)) / df_feat['close'].shift(5)
    df_feat['price_position'] = (df_feat['close'] - df_feat['close'].rolling(20).min()) / \
                                 (df_feat['close'].rolling(20).max() - df_feat['close'].rolling(20).min())
    return df_feat

df_features = create_features(close).dropna()
print(f"Created {len(df_features.columns)} features: {df_features.columns.tolist()}")

# Scale features and target
feature_scaler = MinMaxScaler()
scaled_features = feature_scaler.fit_transform(df_features.values)

target_scaler = MinMaxScaler()
scaled_target = target_scaler.fit_transform(df_features['close'].values.reshape(-1, 1))

# CELL 4: Create Sequences
def create_sequences(data, seq_length):
    X, y = [], []
    for i in range(seq_length, len(data)):
        X.append(data[i-seq_length:i, 0])
        y.append(data[i, 0])
    return np.array(X), np.array(y)

def create_multifeature_sequences(features, target, seq_length):
    X, y = [], []
    for i in range(seq_length, len(features)):
        X.append(features[i-seq_length:i])
        y.append(target[i, 0])
    return np.array(X), np.array(y)

SEQUENCE_LENGTH = 60

# Multi-feature sequences
X_multi, y_multi = create_multifeature_sequences(scaled_features, scaled_target, SEQUENCE_LENGTH)
train_size = int(len(X_multi) * 0.8)
X_train_multi, X_test_multi = X_multi[:train_size], X_multi[train_size:]
y_train_multi, y_test_multi = y_multi[:train_size], y_multi[train_size:]

# Single-feature sequences (for baseline LSTM)
X_single, y_single = create_sequences(scaled_target, SEQUENCE_LENGTH)
train_size_s = int(len(X_single) * 0.8)
X_train_single = X_single[:train_size_s].reshape(-1, SEQUENCE_LENGTH, 1)
X_test_single = X_single[train_size_s:].reshape(-1, SEQUENCE_LENGTH, 1)
y_train_single, y_test_single = y_single[:train_size_s], y_single[train_size_s:]

print(f"Multi-feature: X_train={X_train_multi.shape}, X_test={X_test_multi.shape}")
print(f"Single-feature: X_train={X_train_single.shape}, X_test={X_test_single.shape}")

NUM_FEATURES = X_train_multi.shape[2]

# CELL 5: Model Definitions

# Ultra-Simple CNN-LSTM (no BatchNorm!)
def build_simple_cnn_lstm(input_shape):
    model = Sequential([
        Conv1D(32, 3, padding='causal', input_shape=input_shape),
        LSTM(50, return_sequences=False),
        Dense(1)
    ])
    model.compile(optimizer=tf.keras.optimizers.Adam(0.001), loss='mse', metrics=['mae'])
    return model

# CNN-LSTM V2
def build_cnn_lstm_v2(input_shape):
    model = Sequential([
        Conv1D(64, 3, padding='causal', input_shape=input_shape),
        Conv1D(32, 3, padding='causal'),
        LSTM(64, return_sequences=True),
        Dropout(0.1),
        LSTM(32, return_sequences=False),
        Dense(16),
        Dense(1)
    ])
    model.compile(optimizer=tf.keras.optimizers.Adam(0.001), loss='mse', metrics=['mae'])
    return model

# CNN-LSTM V3 with Attention
def build_cnn_lstm_v3(input_shape):
    inputs = Input(shape=input_shape)
    conv1 = Conv1D(32, 3, padding='causal')(inputs)
    conv2 = Conv1D(32, 3, padding='causal')(conv1)
    attention = Conv1D(1, 1, activation='sigmoid')(conv2)
    attention = Lambda(lambda x: x * input_shape[0])(attention)
    attended = Multiply()([conv2, attention])
    lstm1 = LSTM(64, return_sequences=True)(attended)
    lstm2 = LSTM(32, return_sequences=False)(lstm1)
    dense = Dense(16)(lstm2)
    outputs = Dense(1)(dense)
    model = Model(inputs, outputs)
    model.compile(optimizer=tf.keras.optimizers.Adam(0.001), loss='mse', metrics=['mae'])
    return model

# CNN-LSTM V4 - Parallel Branches (BEST!)
def build_cnn_lstm_v4(input_shape):
    inputs = Input(shape=input_shape)
    
    # CNN Branch
    cnn = Conv1D(32, 3, padding='causal')(inputs)
    cnn = Conv1D(16, 3, padding='causal')(cnn)
    cnn = LSTM(32, return_sequences=False)(cnn)
    
    # Direct LSTM Branch
    lstm = LSTM(32, return_sequences=True)(inputs)
    lstm = LSTM(32, return_sequences=False)(lstm)
    
    # Merge
    merged = Concatenate()([cnn, lstm])
    dense = Dense(32)(merged)
    dense = Dense(16)(dense)
    outputs = Dense(1)(dense)
    
    model = Model(inputs, outputs)
    model.compile(optimizer=tf.keras.optimizers.Adam(0.001), loss='mse', metrics=['mae'])
    return model

# Simple LSTM
def build_lstm(input_shape):
    model = Sequential([
        LSTM(64, return_sequences=True, input_shape=input_shape),
        LSTM(32, return_sequences=False),
        Dense(16),
        Dense(1)
    ])
    model.compile(optimizer=tf.keras.optimizers.Adam(0.001), loss='mse', metrics=['mae'])
    return model

# CELL 6: Training
early_stop = EarlyStopping(monitor='val_loss', patience=25, restore_best_weights=True, verbose=1)
reduce_lr = ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=15, min_lr=0.0001, verbose=1)

results = {}
predictions = {}

# Train models
models_config = [
    ('CNN-LSTM Simple', build_simple_cnn_lstm, X_train_multi, y_train_multi, X_test_multi, y_test_multi),
    ('CNN-LSTM V2', build_cnn_lstm_v2, X_train_multi, y_train_multi, X_test_multi, y_test_multi),
    ('CNN-LSTM V3 Attention', build_cnn_lstm_v3, X_train_multi, y_train_multi, X_test_multi, y_test_multi),
    ('CNN-LSTM V4 Parallel', build_cnn_lstm_v4, X_train_multi, y_train_multi, X_test_multi, y_test_multi),
    ('LSTM Multi-Feature', build_lstm, X_train_multi, y_train_multi, X_test_multi, y_test_multi),
    ('LSTM Single-Feature', build_lstm, X_train_single, y_train_single, X_test_single, y_test_single),
]

for name, builder, X_tr, y_tr, X_te, y_te in models_config:
    print(f"\n{'='*50}\nTraining: {name}\n{'='*50}")
    
    tf.keras.backend.clear_session()
    model = builder((X_tr.shape[1], X_tr.shape[2]))
    
    model.fit(X_tr, y_tr, epochs=150, batch_size=32, validation_split=0.1,
              callbacks=[early_stop, reduce_lr], verbose=1)
    
    # Predict and evaluate
    y_pred_scaled = model.predict(X_te, verbose=0)
    y_pred = target_scaler.inverse_transform(y_pred_scaled.reshape(-1, 1))
    y_actual = target_scaler.inverse_transform(y_te.reshape(-1, 1))
    
    predictions[name] = y_pred
    
    mse = mean_squared_error(y_actual, y_pred)
    rmse = np.sqrt(mse)
    mae = mean_absolute_error(y_actual, y_pred)
    r2 = r2_score(y_actual, y_pred)
    var_ratio = np.std(y_pred) / np.std(y_actual)
    
    results[name] = {'MSE': mse, 'RMSE': rmse, 'MAE': mae, 'R2': r2, 'VarRatio': var_ratio}
    
    print(f"\n{name}: RMSE={rmse:.2f}, R2={r2:.4f}, VarRatio={var_ratio:.2%}")

# CELL 7: Results
print("\n" + "="*60)
print("FINAL RESULTS")
print("="*60)

results_df = pd.DataFrame(results).T.sort_values('R2', ascending=False)
print(results_df.round(4))

best = results_df.index[0]
print(f"\nBest Model: {best} with R2={results_df.loc[best, 'R2']:.4f}")

# Check CNN-LSTM vs LSTM
cnn_models = [k for k in results.keys() if 'CNN-LSTM' in k]
best_cnn = max(cnn_models, key=lambda x: results[x]['R2'])
lstm_r2 = results['LSTM Multi-Feature']['R2']

if results[best_cnn]['R2'] > lstm_r2:
    print(f"\nSUCCESS! {best_cnn} (R2={results[best_cnn]['R2']:.4f}) beats LSTM (R2={lstm_r2:.4f})")
else:
    print(f"\nLSTM still better. Try: increase epochs, adjust learning rate, add more features")

# CELL 8: Visualization
y_actual_plot = target_scaler.inverse_transform(y_test_multi.reshape(-1, 1))

fig, axes = plt.subplots(2, 2, figsize=(16, 12))
fig.suptitle('CNN-LSTM vs LSTM - Final Comparison', fontsize=16, fontweight='bold')

# Predictions
axes[0,0].plot(y_actual_plot, label='Actual', color='gold', linewidth=2)
axes[0,0].plot(predictions[best_cnn], label=best_cnn, color='green', alpha=0.8)
axes[0,0].plot(predictions['LSTM Multi-Feature'], label='LSTM', color='red', linestyle='--', alpha=0.8)
axes[0,0].legend()
axes[0,0].set_title('Predictions vs Actual')
axes[0,0].grid(True, alpha=0.3)

# Zoomed
axes[0,1].plot(y_actual_plot[-100:], label='Actual', color='gold', linewidth=2)
axes[0,1].plot(predictions[best_cnn][-100:], label=best_cnn, color='green')
axes[0,1].plot(predictions['LSTM Multi-Feature'][-100:], label='LSTM', color='red', linestyle='--')
axes[0,1].legend()
axes[0,1].set_title('Last 100 Points')
axes[0,1].grid(True, alpha=0.3)

# R2 comparison
names = list(results.keys())
r2s = [results[n]['R2'] for n in names]
colors = ['green' if 'CNN-LSTM' in n else 'red' for n in names]
axes[1,0].barh(names, r2s, color=colors, alpha=0.7)
axes[1,0].set_xlabel('R2 Score')
axes[1,0].set_title('R2 Comparison')
axes[1,0].axvline(x=0, color='black', linestyle='-')
axes[1,0].grid(True, alpha=0.3, axis='x')

# Variance ratio
var_ratios = [results[n]['VarRatio'] for n in names]
axes[1,1].barh(names, var_ratios, color=colors, alpha=0.7)
axes[1,1].axvline(x=1.0, color='gold', linestyle='--', linewidth=2, label='Target (1.0)')
axes[1,1].set_xlabel('Variance Ratio')
axes[1,1].set_title('Variance Ratio (Should be ~1.0)')
axes[1,1].legend()
axes[1,1].grid(True, alpha=0.3, axis='x')

plt.tight_layout()
plt.savefig('final_results.png', dpi=150)
plt.show()

print("\nDone! Check 'final_results.png'")
